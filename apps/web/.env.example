# Public site URL
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Clerk (optional for guest mode)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=REPLACE_WITH_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=REPLACE_WITH_CLERK_SECRET_KEY

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Anthropic (used by scripts/suggest-resources.mjs to auto-populate content/resources.json)
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_API_KEY

# Supabase (optional unless progress sync is enabled)
# Use the public key value from the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=REPLACE_WITH_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=REPLACE_WITH_SUPABASE_PUBLISHABLE_DEFAULT_KEY
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=REPLACE_WITH_WEB3FORMS_ACCESS_KEY
