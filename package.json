{
  "name": "js-questions-lab",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "sync:upstream": "node scripts/sync-upstream.mjs",
    "parse:questions": "node scripts/parse-readme.mjs",
    "parse:react": "node scripts/parse-react-patterns.mjs",
    "content:react": "bun run parse:react",
    "content:refresh": "bun run sync:upstream && bun run parse:questions",
    "clean": "find . -name node_modules -o -name .next -o -name .turbo -o -name dist -type d -prune | xargs rm -rf",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "bunx biome check .",
    "lint:md": "bunx markdownlint-cli2 .",
    "lint:md:fix": "bunx markdownlint-cli2 --fix",
    "lint:fix": "bunx biome check --write .",
    "format": "bunx biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "turbo": "^2.9.6"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@types/prettier": "^3.0.0",
    "@uiw/codemirror-theme-vscode": "^4.25.9",
    "@uiw/react-codemirror": "^4.25.9",
    "prettier": "^3.8.1"
  }
}
