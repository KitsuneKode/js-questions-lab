{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["bun.lock", "content/generated/**", "content/source/**", "biome.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^typecheck", ".env*"],
      "env": [
        "CLERK_SECRET_KEY",
        "NEXT_PUBLIC_SITE_URL",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {},
    "dev": {
      "cache": false,
      "persistent": true,
      "env": []
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
